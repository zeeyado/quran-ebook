<?xml version="1.0" encoding="utf-8"?>
<!DOCTYPE html>
<html xmlns="http://www.w3.org/1999/xhtml" xmlns:epub="http://www.idpf.org/2007/ops" xml:lang="ar" lang="ar" dir="rtl">
<head>
    <meta charset="utf-8"/>
    <title>سورة {{ surah.name_arabic }}</title>
    <link rel="stylesheet" type="text/css" href="styles/base.css"/>
</head>
<body>
    <table class="surah-header"><tr>
        <td class="header-info">ترتيبها<br/><span class="header-num plain-num">{{ surah.number | arabic_numerals }}</span></td>
        <td class="surah-name" id="surah-{{ surah.number }}"><span class="surah-glyph" dir="ltr">surah{{ '%03d'|format(surah.number) }}surah-icon</span></td>
        <td class="header-info">آياتها<br/><span class="header-num plain-num">{{ surah.ayah_count | arabic_numerals }}</span></td>
    </tr></table>
{%- if surah.has_bismillah and not surah.bismillah_is_first_ayah %}
    <table class="bismillah-table"><tr><td class="bismillah">{{ bismillah_text }}</td></tr></table>
{%- endif %}
{%- for line in lines %}
{%- if line.is_first_on_page %}<span epub:type="pagebreak" role="doc-pagebreak" id="page{{ line.page_number }}" title="{{ line.page_number }}"></span>{% endif %}
    <div class="qcf-line">{% if line.hizb_marker %}&#8288;<span class="hizb-marker">۞</span> {% endif %}{% for word in line.words %}{% if word.char_type == 'end' %}&#8288;<a class="ayah-noteref" epub:type="noteref" href="endnotes.xhtml#trans-{{ word.surah_number }}-{{ word.ayah_number }}"><span class="qcf-word qcf-end qcf-p{{ word.page_number }}" id="ayah-{{ word.surah_number }}-{{ word.ayah_number }}">{{ word.code_v2 }}</span></a>{% else %}{% if not loop.first or line.hizb_marker %} {% endif %}<span class="qcf-word qcf-p{{ word.page_number }}" data-uthmani="{{ word.text }}">{{ word.code_v2 }}</span>{% endif %}{% endfor %}</div>
{%- endfor %}
</body>
</html>
