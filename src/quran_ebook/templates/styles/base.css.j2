@font-face {
    font-family: '{{ font_family }}';
    src: url('../fonts/{{ font_filename }}') format('truetype');
    font-weight: normal;
    font-style: normal;
}

@font-face {
    font-family: '{{ symbol_font_family }}';
    src: url('../fonts/{{ symbol_font_filename }}') format('truetype');
    font-weight: normal;
    font-style: normal;
}

@font-face {
    font-family: '{{ basmala_font_family }}';
    src: url('../fonts/{{ basmala_font_filename }}') format('truetype');
    font-weight: normal;
    font-style: normal;
}

@font-face {
    font-family: '{{ header_label_font_family }}';
    src: url('../fonts/{{ header_label_font_filename }}') format('truetype');
    font-weight: normal;
    font-style: normal;
}

@font-face {
    font-family: '{{ surah_name_font_family }}';
    src: url('../fonts/{{ surah_name_font_filename }}') format('truetype');
    font-weight: normal;
    font-style: normal;
}

/* Global table border reset — e-readers apply default borders to tables */
table, tr, td, th {
    border: none !important;
}

body {
    margin: 0;
    padding: 0;
    text-indent: 0;
    font-family: '{{ font_family }}', 'Scheherazade New', serif;
    font-size: 1.5em;
    color: #1a1a1a;
    background: #fff;
}

/* Plain numbers — use symbol font to bypass KFGQPC digit-as-ayah-marker glyphs */
.plain-num {
    font-family: '{{ symbol_font_family }}', serif;
}

/* === Surah headers === */

table.surah-header {
    width: 100%;
    border-collapse: collapse;
    border-top: 1px solid #999 !important;
    border-bottom: 1px solid #999 !important;
    margin: 1em 0 0.5em 0;
}

table.surah-header td {
    padding: 0.25em 0;
    vertical-align: middle;
    border: none;
}

/* Center cell — contains calligraphic glyph + transliteration (bilingual) */
table.surah-header .surah-name {
    text-align: center;
    font-size: 1.5em;
    line-height: 1.1;
    white-space: nowrap;
    padding: 0.05em 0.3em;
}

/* Calligraphic surah name glyph — ligature font renders ASCII triggers
   (e.g. "s001") as mushaf-style Arabic calligraphy.
   dir="ltr" is set on the HTML element (EPUB CSS forbids direction/unicode-bidi). */
.surah-glyph {
    font-family: '{{ surah_name_font_family }}', serif;
    font-size: 1.6em;
    line-height: 1;
    vertical-align: middle;
}

/* Plain surah name header — no table, no borders (KFGQPC riwayat). */
.surah-name-plain {
    text-align: center;
    margin: 0.5em 0 0.2em 0;
}

/* Fallback surah name — plain Arabic text in primary font (used when
   calligraphic glyph font is not available for the riwayah). */
.surah-name-text {
    font-family: '{{ font_family }}', serif;
    font-size: 1.3em;
    line-height: 1.2;
}

/* Side columns — surah number + ayah count */
table.surah-header .header-info {
    width: 18%;
    font-family: '{{ header_label_font_family }}', serif;
    font-size: 0.7em;
    color: #555;
    white-space: nowrap;
    text-align: center;
    line-height: 1.3;
    padding: 0 0.3em;
}

/* Latin transliteration + translated meaning below surah glyph (bilingual only) */
.header-transliteration {
    font-family: serif;
    font-size: 0.45em;
    color: #666;
    letter-spacing: 0.03em;
    display: block;
    line-height: 1.2;
    padding-bottom: 0.5em;
}

/* === Bismillah === */

table.bismillah-table {
    width: 100%;
    border-collapse: collapse;
    border: none;
    margin: 0 0 0.3em 0;
}

table.bismillah-table td {
    border: none;
}

.bismillah {
    text-align: center;
    font-family: '{{ basmala_font_family }}', serif;
    font-size: 1.5em;
    line-height: 1.7;
    padding: 0;
}

/* === Quranic Arabic text === */

/* Ayah-per-line mode (by_surah / bilingual layouts) */
.ayah-text {
    font-size: 1em;
    line-height: 1.7;
    text-align: center;
    margin: 0;
    break-inside: avoid;
}

/* Inline flowing text mode (inline / interactive layouts) */
.surah-text {
    font-size: 1em;
    line-height: 1.7;
    text-align: justify;
    margin: 0.2em 0 0 0;
}

/* Ayah number markers — KFGQPC renders digits as ornate circle markers.
   inline-block ensures margin is honoured by CREngine and keeps spacing
   immune to text-align:justify stretching. Break control is handled by
   WJ/ZWS in the templates, not by margin asymmetry. */
.ayah-number {
    display: inline-block;
    font-size: 1.2em;
    line-height: 1;
    color: #000;
    margin: 0 0.06em;
}

/* Hizb marker — ornamental rub al-hizb (۞).
   inline-block for the same reason as .ayah-number above. */
.hizb-marker {
    display: inline-block;
    font-family: '{{ hizb_font_family }}', serif;
    font-size: {{ hizb_font_size }};
    vertical-align: middle;
    color: #000;
    margin: 0 0.06em;
}

/* Interactive inline — ayah markers as noteref links (no visual change) */
.ayah-noteref {
    text-decoration: none !important;
    color: inherit;
}

/* Footnote reference numbers in translation text */
.noteref {
    font-size: 0.75em;
    vertical-align: super;
    color: #666;
    text-decoration: none;
}

/* === Translation & endnotes === */

/* Bilingual ayah-by-ayah — no wrapper div, styling on elements directly */
.ayah-text.bilin {
    text-align: right;
    text-indent: 0;
    margin-top: 0.5em;
}

.translation {
    padding-bottom: 0.3em;
    border-bottom: 1px solid #eee;
}

/* Translation text — inline (bilingual) */
.translation {
    font-family: serif;
    font-size: {{ translation_font_size }};
    line-height: 1.5;
    color: #333;
    text-align: start;
    margin: 0.2em 0 0 0;
    break-inside: avoid;
}

/* Surah:ayah reference (e.g. "2:255") */
.ayah-ref {
    font-family: serif;
    font-size: 0.85em;
    color: #999;
}

/* Endnote content — translation popups, footnotes, inline footnotes.
   Unified class replacing old .translation-note, .footnote-text, .inline-footnote. */
.endnote {
    font-family: serif;
    font-size: {{ translation_font_size }};
    line-height: 1.5;
    color: #333;
    margin: 0.3em 0;
}

/* === Word-by-Word Interlinear === */

.wbw-ayah {
    text-align: right;
    margin: 0.8em 0 0.2em 0;
    line-height: 1.1;
}

.wbw-word {
    display: inline-table;
    text-align: center;
    margin: 0 0.08em 0.4em 0.08em;
    padding-bottom: 0.2em;
    border-bottom: 0.5px solid #ddd;
    vertical-align: top;
}

/* WBW translation — slightly more breathing room below than bilingual */
.wbw-ayah + .translation {
    padding-bottom: 0.5em;
}

/* Hizb marker wrapped in wbw-word for vertical alignment */
.wbw-marker {
    margin-bottom: 0;
    padding-bottom: 0;
    border-bottom: none;
}



.wbw-arabic {
    display: table-row;
    font-family: '{{ font_family }}', serif;
    font-size: 1em;
    line-height: 1.8;
}

.wbw-gloss {
    display: table-row;
    font-family: serif;
    font-size: {{ wbw_gloss_font_size }};
    color: #555;
    white-space: nowrap;
    line-height: 1.1;
}

.wbw-translit {
    display: table-row;
    font-family: serif;
    font-size: 0.35em;
    color: #888;
    font-style: italic;
    white-space: nowrap;
    line-height: 1.2;
}
