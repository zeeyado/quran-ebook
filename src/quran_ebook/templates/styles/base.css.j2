@font-face {
    font-family: '{{ font_family }}';
    src: url('../fonts/{{ font_filename }}') format('truetype');
    font-weight: normal;
    font-style: normal;
}

@font-face {
    font-family: '{{ symbol_font_family }}';
    src: url('../fonts/{{ symbol_font_filename }}') format('truetype');
    font-weight: normal;
    font-style: normal;
}

@font-face {
    font-family: '{{ basmala_font_family }}';
    src: url('../fonts/{{ basmala_font_filename }}') format('truetype');
    font-weight: normal;
    font-style: normal;
}

@font-face {
    font-family: '{{ surah_name_font_family }}';
    src: url('../fonts/{{ surah_name_font_filename }}') format('truetype');
    font-weight: normal;
    font-style: normal;
}

/* Global table border reset — e-readers apply default borders to tables */
table, tr, td, th {
    border: none !important;
}

body {
    margin: 0;
    padding: 0;
    text-indent: 0;
    font-family: '{{ font_family }}', 'Scheherazade New', serif;
    font-size: 1.5em;
    color: #1a1a1a;
    background: #fff;
}

/* Plain numbers — use symbol font to bypass KFGQPC digit-as-ayah-marker glyphs */
.plain-num {
    font-family: '{{ symbol_font_family }}', serif;
}

/* === Surah headers === */

table.surah-header {
    width: 100%;
    border-collapse: collapse;
    border-top: 1px solid #999 !important;
    border-bottom: 1px solid #999 !important;
    margin: 1em 0 0.5em 0;
}

table.surah-header td {
    padding: 0.25em 0;
    vertical-align: middle;
    border: none;
}

/* Center cell — contains calligraphic glyph + transliteration (bilingual) */
table.surah-header .surah-name {
    text-align: center;
    font-size: 1.5em;
    line-height: 1.1;
    white-space: nowrap;
    padding: 0.05em 0.3em;
}

/* Calligraphic surah name glyph — ligature font renders ASCII triggers
   (e.g. "s001") as mushaf-style Arabic calligraphy.
   dir="ltr" is set on the HTML element (EPUB CSS forbids direction/unicode-bidi). */
.surah-glyph {
    font-family: '{{ surah_name_font_family }}', serif;
    font-size: 1.6em;
    line-height: 1;
    vertical-align: middle;
}

/* Side columns — surah number + ayah count */
table.surah-header .header-info {
    width: 18%;
    font-family: '{{ symbol_font_family }}', serif;
    font-size: 0.7em;
    color: #555;
    white-space: nowrap;
    text-align: center;
    line-height: 1.3;
    padding: 0 0.3em;
}

/* Latin transliteration + translated meaning below surah glyph (bilingual only) */
.header-transliteration {
    font-family: serif;
    font-size: 0.45em;
    color: #666;
    letter-spacing: 0.03em;
    display: block;
    line-height: 1.2;
    padding-bottom: 0.5em;
}

/* === Bismillah === */

table.bismillah-table {
    width: 100%;
    border-collapse: collapse;
    border: none;
    margin: 0 0 0.5em 0;
}

table.bismillah-table td {
    border: none;
}

.bismillah {
    text-align: center;
    font-family: '{{ basmala_font_family }}', serif;
    font-size: 1.5em;
    line-height: 1.7;
    padding: 0;
}

/* === Quranic Arabic text === */

/* Ayah-per-line mode (by_surah / bilingual layouts) */
.ayah-text {
    font-size: 1em;
    line-height: 1.7;
    text-align: center;
    margin: 0;
}

/* Inline flowing text mode (inline / interactive layouts) */
.surah-text {
    font-size: 1em;
    line-height: 1.7;
    text-align: justify;
    margin: 0;
}

/* Ayah number markers — KFGQPC renders digits as ornate circle markers */
.ayah-number {
    font-size: 1.2em;
    line-height: 1;
    color: #000;
}

/* Hizb marker — Scheherazade New ornamental 8-petaled flower */
.hizb-marker {
    font-family: '{{ symbol_font_family }}', serif;
    font-size: 0.8em;
    color: #000;
}

/* Interactive inline — ayah markers as noteref links (no visual change) */
.ayah-noteref {
    text-decoration: none !important;
    color: inherit;
}

/* Footnote reference numbers in translation text */
.noteref {
    font-size: 0.75em;
    vertical-align: super;
    color: #666;
    text-decoration: none;
}

/* === Translation & endnotes === */

/* Bilingual ayah-by-ayah wrapper */
.ayah-block {
    margin: 0.5em 0;
    padding-bottom: 0.3em;
    border-bottom: 1px solid #eee;
}

.ayah-block .ayah-text {
    text-align: right;
    text-indent: 0;
}

/* Translation text — inline (bilingual) */
.translation {
    font-family: serif;
    font-size: {{ translation_font_size }};
    line-height: 1.5;
    color: #333;
    text-align: start;
    margin: 0.2em 0 0 0;
}

/* Surah:ayah reference (e.g. "2:255") */
.ayah-ref {
    font-family: serif;
    font-size: 0.85em;
    color: #999;
}

/* Endnote content — translation popups, footnotes, inline footnotes.
   Unified class replacing old .translation-note, .footnote-text, .inline-footnote. */
.endnote {
    font-family: serif;
    font-size: {{ translation_font_size }};
    line-height: 1.5;
    color: #333;
    margin: 0.3em 0;
}
