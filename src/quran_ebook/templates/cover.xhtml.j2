<?xml version="1.0" encoding="utf-8"?>
<!DOCTYPE html>
<html xmlns="http://www.w3.org/1999/xhtml" xml:lang="ar" lang="ar" dir="rtl">
<head>
    <meta charset="utf-8"/>
    <title>{{ title }}</title>
    <style>
{%- if font_family and font_filename %}
        @font-face {
            font-family: '{{ font_family }}';
            src: url('fonts/{{ font_filename }}') format('truetype');
        }
{%- endif %}
{%- if cover_font_family and cover_font_filename %}
        @font-face {
            font-family: '{{ cover_font_family }}';
            src: url('fonts/{{ cover_font_filename }}') format('truetype');
        }
{%- endif %}
{%- if symbol_font_family and symbol_font_filename %}
        @font-face {
            font-family: '{{ symbol_font_family }}';
            src: url('fonts/{{ symbol_font_filename }}') format('truetype');
        }
{%- endif %}
        html, body {
            margin: 0;
            padding: 0;
            height: 100%;
{%- if font_family %}
            font-family: '{{ font_family }}', serif;
{%- endif %}
        }
        table, tr, td { border: none !important; }
        .cover-wrap {
            width: 100%;
            height: 100%;
            border: none;
            border-collapse: collapse;
        }
        .cover-wrap td {
            text-align: center;
        }
        .cover-main-cell {
            vertical-align: top;
            padding: 12em 1em 0 1em;
        }
        .cover-title {
{%- if cover_font_family %}
            font-family: '{{ cover_font_family }}', serif;
{%- endif %}
            font-size: 8em;
            line-height: 1.2;
            text-align: center;
            text-indent: 0;
            margin: 0;
            padding: 0;
        }
        .cover-subtitle {
{%- if symbol_font_family %}
            font-family: '{{ symbol_font_family }}', serif;
{%- endif %}
            font-size: 1.4em;
            color: #444;
            text-align: center;
            text-indent: 0;
            margin: 0;
            padding: 2em 0 0 0;
        }
        .cover-layout-desc {
{%- if symbol_font_family %}
            font-family: '{{ symbol_font_family }}', serif;
{%- endif %}
            font-size: 1em;
            color: #888;
            text-align: center;
            text-indent: 0;
            margin: 0;
            padding: 0.05em 0;
        }
        .cover-translation-label {
            font-family: serif;
            font-size: 0.85em;
            color: #555;
            text-align: center;
            text-indent: 0;
            margin: 0;
            padding: 0.05em 0;
        }
        .cover-version-cell {
            vertical-align: bottom;
            height: 2em;
            padding: 3em 1em 1em 1em;
        }
        .cover-version {
            font-family: monospace;
            font-size: 0.6em;
            color: #bbb;
            text-align: left;
            text-indent: 0;
            margin: 0;
            padding: 0;
        }
    </style>
</head>
<body>
    <table class="cover-wrap">
        <tr><td class="cover-main-cell">
            <p class="cover-title">&#xE076;</p>
{%- if subtitle %}
            <p class="cover-subtitle">{{ subtitle }}</p>
{%- endif %}
{%- if layout_descriptor %}
            <p class="cover-layout-desc">{{ layout_descriptor }}</p>
{%- endif %}
{%- if translation_label %}
            <p class="cover-translation-label">{{ translation_label }}</p>
{%- endif %}
        </td></tr>
{%- if version %}
        <tr><td class="cover-version-cell">
            <p class="cover-version" dir="ltr">{{ version }}</p>
        </td></tr>
{%- endif %}
    </table>
</body>
</html>
